# 토스 Open API 자격증명
# 발급: 토스증권 PC 웹 → 설정 → Open API (client_id / client_secret)
#
# 사용법: 이 파일을 같은 폴더에 ".env" 로 복사한 뒤 값을 채우세요.
#         실제 .env 는 .gitignore 로 커밋이 차단됩니다. 절대 공유/커밋 금지.

TOSS_CLIENT_ID=your_client_id_here
TOSS_CLIENT_SECRET=your_client_secret_here

# (선택) 스모크에서 조회할 종목코드. 기본값 005930(삼성전자).
# SMOKE_SYMBOL=005930
