# 토스 Open API 자격증명
# 발급: 토스증권 PC 웹 → 설정 → Open API (client_id / client_secret)
#
# 사용법: 이 파일을 같은 폴더에 ".env" 로 복사한 뒤 값을 채우세요.
#         실제 .env 는 .gitignore 로 커밋이 차단됩니다. 절대 공유/커밋 금지.

TOSS_CLIENT_ID=your_client_id_here
TOSS_CLIENT_SECRET=your_client_secret_here
# TOSS_ACCOUNT_SEQ=1                              # 생략 시 자동 판별

# ── 상시 페이퍼 운용(로컬 서버 런처 run_local.py 가 이 파일을 process env 로 로드) ──
# 자세한 안내: ../../USAGE.md
# DATABASE_URL=sqlite+aiosqlite:///./trading.db   # 영속화(페이퍼 장부·엔진 상태·로테이션)
# SYMBOL_SOURCE_PATH=data/krx_symbols.json        # 전 종목 유니버스(코호트 순환)
# TICK_INTERVAL_SEC=300                           # 내장 틱 루프(0=비활성) — KST 장중에만 실행
# ANTHROPIC_API_KEY=sk-ant-...                    # LLM 판단(없으면 결정적 폴백)
# API_KEY=change-me                               # /api/* 인증 키(기본 dev-local-key)

# (선택) 스모크에서 조회할 종목코드. 기본값 005930(삼성전자).
# SMOKE_SYMBOL=005930
